{
  "name": "@floegence/redeven-desktop",
  "private": true,
  "version": "0.1.0",
  "description": "Redeven Desktop shell",
  "author": "Floegence",
  "homepage": "https://github.com/floegence/redeven",
  "main": "dist/main/main.js",
  "scripts": {
    "prepare:bundled-runtime": "../scripts/build_desktop_bundled_runtime.sh",
    "start": "npm run build && npm run prepare:bundled-runtime && electron .",
    "build": "tsc -p tsconfig.json && node dist/build/buildPreloads.js && vite build --config vite.welcome.config.mjs",
    "lint": "eslint \"src/**/*.ts\" \"src/**/*.tsx\" \"electron-builder.config.mjs\" \"eslint.config.mjs\" \"vite.welcome.config.mjs\" --max-warnings=0",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test": "vitest run",
    "package": "npm run build && npm run prepare:bundled-runtime && electron-builder --config electron-builder.config.mjs --publish never"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "overrides": {
    "dompurify": "^3.4.0",
    "lodash": "^4.18.1",
    "lodash-es": "^4.18.1",
    "picomatch": "^4.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@floegence/floe-webapp-core": "^0.36.9",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/iosevka": "^5.2.5",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^20.19.24",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "electron": "41.1.0",
    "electron-builder": "26.8.1",
    "electron-builder-squirrel-windows": "26.8.1",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "solid-js": "^1.9.12",
    "solid-motionone": "^1.0.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "vite-plugin-solid": "^2.11.10",
    "vitest": "^3.2.4"
  }
}
