{
  "name": "@floegence/redeven-envapp-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"vite.config.ts\" \"vitest.browser.config.ts\" \"eslint.config.mjs\" --max-warnings=0",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" \"vite.config.ts\" \"vitest.browser.config.ts\" \"eslint.config.mjs\" --fix",
    "preview": "vite preview --host 0.0.0.0 --port 8096",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --environment=node --exclude \"src/**/*.browser.test.tsx\"",
    "test:browser": "vitest run --config vitest.browser.config.ts"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.5",
    "@floegence/floe-webapp-core": "^0.35.54",
    "@floegence/floe-webapp-protocol": "^0.35.54",
    "@floegence/floeterm-terminal-web": "^0.4.12",
    "@floegence/flowersec-core": "^0.18.0",
    "@fontsource/iosevka": "^5.2.5",
    "@solidjs/router": "^0.15.3",
    "diff": "^8.0.3",
    "docx-preview": "^0.3.6",
    "exceljs": "^4.4.0",
    "marked": "^17.0.2",
    "mermaid": "^11.12.2",
    "shiki": "^3.22.0",
    "solid-js": "^1.9.3",
    "solid-motionone": "^1.0.4"
  },
  "overrides": {
    "@floegence/flowersec-core": "^0.18.0",
    "dompurify": "^3.3.3",
    "flatted": "^3.4.2",
    "lodash-es": "^4.18.1",
    "minimatch@^3.0.0": "^3.1.4",
    "minimatch@^5.0.0": "^5.1.8",
    "picomatch": "^4.0.4",
    "rollup": "^4.59.0"
  },
  "pnpm": {
    "overrides": {
      "@floegence/flowersec-core": "^0.18.0",
      "dompurify": "^3.3.3",
      "flatted": "^3.4.2",
      "lodash-es": "^4.18.1",
      "minimatch@^3.0.0": "^3.1.4",
      "minimatch@^5.0.0": "^5.1.8",
      "picomatch": "^4.0.4",
      "rollup": "^4.59.0"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.0.0",
    "@types/diff": "^8.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/browser": "^3.2.4",
    "eslint": "^9.39.4",
    "eslint-plugin-solid": "^0.14.5",
    "globals": "^17.4.0",
    "jsdom": "^26.1.0",
    "playwright": "^1.57.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.4.2",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^3.2.4"
  }
